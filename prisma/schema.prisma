
generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  role          Role      @default(CLIENT)
  specialization String?
  bio           String?
  phone         String?
  country       String?
  city          String?
  location      String?
  legalType     String? 
  taxId         String?
  verified      Boolean   @default(false)
  blocked       Boolean   @default(false)
  rating        Decimal   @default(5.0) @db.Decimal(3, 1)
  reviewsCount  Int       @default(0)
  completedJobs Int       @default(0)
  successRate   Int       @default(100)
  experience    String?
  createdAt     DateTime  @default(now())

  services      Service[]
  clientBookings  Booking[] @relation("ClientBookings")
  providerBookings Booking[] @relation("ProviderBookings")
  reviews       Review[]

  @@index([role])
}

model Service {
  id          String   @id @default(cuid())
  providerId  String
  provider    User     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  title       String
  description String
  priceUSD    Decimal  @db.Decimal(10, 2)
  category    String
  images      String[] @default([])
  hidden      Boolean  @default(false)
  rating      Decimal  @default(5.0) @db.Decimal(3, 1)
  createdAt   DateTime @default(now())

  bookings    Booking[]
  reviews     Review[]

  @@index([providerId])
  @@index([category])
}

model Booking {
  id          String         @id @default(cuid())
  clientId    String
  client      User           @relation("ClientBookings", fields: [clientId], references: [id], onDelete: Cascade)
  providerId  String
  provider    User           @relation("ProviderBookings", fields: [providerId], references: [id], onDelete: Cascade)
  serviceId   String
  service     Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceName String
  providerName String
  date        String         
  time        String       
  comment     String?
  priceUSD    Decimal        @db.Decimal(10, 2)
  status      BookingStatus  @default(CONFIRMED)
  createdAt   DateTime       @default(now())

  @@unique([providerId, date, time])
  @@index([providerId, date])   
  @@index([clientId])
}

model Review {
  id          String   @id @default(cuid())
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorName  String
  rating      Int
  text        String
  createdAt   DateTime @default(now())

  @@index([serviceId])
}

model Message {
  id        String   @id @default(cuid())
  fromId    String?
  fromName  String
  toProviderId String
  text      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([toProviderId])
}

enum Role {
  CLIENT
  PROVIDER
  ADMIN
}

enum BookingStatus {
  CONFIRMED       
  CANCELLED_USER  
  CANCELLED_ADMIN 
  REJECTED        
}
